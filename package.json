{
  "name": "pureqr",
  "private": false,
  "version": "1.0.0",
  "description": "A free, client-side QR code encoder with SVG and PNG export.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
